vlib work

vcom -93 bcdcase.vhd

vsim work.bcdcase(ifsc_v1)

add wave -position insertpoint sim:/bcdcase/*

property wave -radix binary sim:/bcdcase/En

property wave -radix binary sim:/bcdcase/Ou



force -freeze sim:/bcdcase/En 0000 0

run 100ns



force -freeze sim:/bcdcase/En 0001 0

run 100ns



force -freeze sim:/bcdcase/En 0111 0

run 100ns



force -freeze sim:/bcdcase/En 1000 0

run 100ns



force -freeze sim:/bcdcase/En 1111 0

run 100ns



wave zoom full