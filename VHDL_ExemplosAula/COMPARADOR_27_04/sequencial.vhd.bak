library ieee;
use ieee.std_logic_1164.all;

entity sequencial is
    port
    (
        -- Input ports
        A: in  std_logic_vector (7 downto 0);
        B: in  std_logic_vector (7 downto 0);

        -- Output ports
        gt: out std_logic;
        eq: out std_logic;
        lt: out std_logic
    );
end entity;

architecture exemplo of sequencial is
begin

    process (a,b)
    begin
        if (a>b) then
            gt <= '1';
        elsif (a=b) then
            eq <= '1';
        else
            lt <= '1';
        end if;
    end process;
    
end architecture;

architecture correcao of sequencial is
begin

process (a,b)
 begin
 
    gt <= '0';
    eq <= '0';
    lt <= '0';
    if (a>b) then
        gt <= '1';
    elsif (a=b) then
        eq <= '1';
    else
        lt <= '1';
    end if;
    
end process;
        
end architecture;


CONFIGURATION cfg_ifsc OF sequencial IS
    FOR exemplo END FOR;
--    FOR correcao END FOR;
END CONFIGURATION;
