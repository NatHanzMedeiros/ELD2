library ieee;
use ieee.std_logic_1164.all;

entity FlipFlopEnable is
	port
	(
		-- Input ports
		D : in  std_logic;
		CLK : in  std_logic;
		E : in std_logic;
		RST : in std_logic;
		
		-- Output ports
		Q	: out std_logic
	);
end entity;

architecture ifsc_v1 of FlipFlopEnable is

begin

	process (CLK , RST , E)
	
begin

if (RST = '1') then 

	Q <= '0';
	
elsif (CLK event and CLK = '1' and E = '1') then 

	Q <= D;

	end if;
	end process;
end ifsc_v1;

